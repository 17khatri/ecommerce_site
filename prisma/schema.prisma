generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL") // ✅ works in v5
}

enum Role {
  ADMIN
  USER
}

model User {
  id          BigInt   @id @default(autoincrement())
  firstName   String
  middleName  String?
  lastName    String
  gender      String
  birthDate   DateTime
  email       String   @unique
  phoneNumber String
  status      Boolean  @default(true)
  password    String?

  role Role @default(USER)

  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model Category {
  id       BigInt  @id @default(autoincrement())
  name     String
  parentId BigInt? // 👈 optional (for parent-child)

  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")

  status    Boolean   @default(true)
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  products Product[]
}

model Brand {
  id     BigInt  @id @default(autoincrement())
  name   String  @unique
  status Boolean @default(true)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  products Product[]
}

model Product {
  id BigInt @id @default(autoincrement())

  categoryId BigInt
  brandId    BigInt

  name        String
  description String?

  status Boolean @default(true)

  variants ProductVariant[]

   images        ProductImage[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  category Category @relation(fields: [categoryId], references: [id])
  brand    Brand    @relation(fields: [brandId], references: [id])

  @@map("products")
}

model ProductVariant {
  id        BigInt @id @default(autoincrement())
  productId BigInt

  sku       String @unique
  price     Float
  quantity  Int

  color     String?
  size      String?

  product   Product @relation(fields: [productId], references: [id])

  deletedAt DateTime?
}


model ProductImage {
  id         BigInt   @id @default(autoincrement())
  productId  BigInt   @map("products_id")
  imagePath  String   @map("image_path")
  isPrimary  Boolean  @default(false) // 👈 NEW FIELD
  createdAt  DateTime @default(now()) @map("created_at")
  status     Boolean  @default(true)

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("products_images")
}